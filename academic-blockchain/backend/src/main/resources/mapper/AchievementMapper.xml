<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cuit.academic.mapper.AchievementMapper">

    <resultMap id="AchievementMap" type="com.cuit.academic.entity.Achievement">
        <id     property="achievementId" column="achievement_id"/>
        <result property="userId"        column="user_id"/>
        <result property="name"          column="name"/>
        <result property="summary"       column="summary"/>
        <result property="category"      column="category"/>
        <result property="status"        column="status"/>
        <result property="createTime"    column="create_time"/>
        <result property="updateTime"    column="update_time"/>
    </resultMap>

    <sql id="Cols">
        achievement_id, user_id, name, summary, category, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="AchievementMap">
        SELECT <include refid="Cols"/> FROM achievement WHERE achievement_id = #{achievementId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="achievementId">
        INSERT INTO achievement(user_id, name, summary, category, status)
        VALUES (#{userId}, #{name}, #{summary}, #{category},
                <choose>
                    <when test="status != null and status != ''">#{status}</when>
                    <otherwise>'CREATED'</otherwise>
                </choose>)
    </insert>

    <update id="update">
        UPDATE achievement
        <set>
            <if test="name     != null">name     = #{name},</if>
            <if test="summary  != null">summary  = #{summary},</if>
            <if test="category != null">category = #{category},</if>
            <if test="status   != null">status   = #{status},</if>
        </set>
        WHERE achievement_id = #{achievementId}
    </update>

    <update id="updateStatus">
        UPDATE achievement SET status = #{status} WHERE achievement_id = #{achievementId}
    </update>

    <delete id="deleteById">
        DELETE FROM achievement WHERE achievement_id = #{achievementId}
    </delete>

    <select id="listByUser" resultMap="AchievementMap">
        SELECT <include refid="Cols"/> FROM achievement WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="listAll" resultMap="AchievementMap">
        SELECT <include refid="Cols"/> FROM achievement
        <where>
            <if test="keyword != null and keyword != ''">
                (name LIKE CONCAT('%', #{keyword}, '%') OR summary LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM achievement
    </select>

    <select id="countByStatus" resultType="long">
        SELECT COUNT(*) FROM achievement WHERE status = #{status}
    </select>
</mapper>
