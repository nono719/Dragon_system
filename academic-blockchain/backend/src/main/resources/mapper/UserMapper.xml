<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cuit.academic.mapper.UserMapper">

    <resultMap id="UserMap" type="com.cuit.academic.entity.User">
        <id     property="userId"        column="user_id"/>
        <result property="username"      column="username"/>
        <result property="walletAddress" column="wallet_address"/>
        <result property="phone"         column="phone"/>
        <result property="email"         column="email"/>
        <result property="role"          column="role"/>
        <result property="createTime"    column="create_time"/>
        <result property="updateTime"    column="update_time"/>
    </resultMap>

    <sql id="Cols">
        user_id, username, wallet_address, phone, email, role, create_time, update_time
    </sql>

    <select id="selectById" resultMap="UserMap">
        SELECT <include refid="Cols"/> FROM `user` WHERE user_id = #{userId}
    </select>

    <select id="selectByWallet" resultMap="UserMap">
        SELECT <include refid="Cols"/> FROM `user` WHERE wallet_address = LOWER(#{walletAddress})
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO `user`(username, wallet_address, phone, email, role)
        VALUES (#{username}, LOWER(#{walletAddress}), #{phone}, #{email},
                <choose>
                    <when test="role != null and role != ''">#{role}</when>
                    <otherwise>'USER'</otherwise>
                </choose>)
    </insert>

    <update id="update">
        UPDATE `user`
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="phone    != null">phone    = #{phone},</if>
            <if test="email    != null">email    = #{email},</if>
            <if test="role     != null">role     = #{role},</if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <select id="listAll" resultMap="UserMap">
        SELECT <include refid="Cols"/> FROM `user` ORDER BY create_time DESC
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM `user`
    </select>
</mapper>
